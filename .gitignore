# Pipfile.lock

# ============================================
# PyInstaller 打包产物
# ============================================
build/
dist/
*.spec.bak
*.spec.orig

# 单独保留 DiaryManager.spec
!DiaryManager.spec

# ============================================
# 旧的废弃代码
# ============================================
commands_old/

# ============================================
# 私人日记数据（绝不上传）
# ============================================
data/*.txt
data/*/*.txt
data/*/*/*.txt
data/*.md
data/*/*.md
data/*/*/*.md

# 但保留 data/ 目录结构（用 .gitkeep 占位）
!data/.gitkeep
!data/*/
!data/*/.gitkeep

# ============================================
# WorkBuddy 工作记忆与技能
# ============================================
.workbuddy/

